def parse_args():
    parser = argparse.ArgumentParser(description="GGUF inference via llama-cpp-python")
    parser.add_argument("--model_path", type=str, default="{{ model_path }}")
    parser.add_argument("--input_file", type=str, default="{{ input_file }}")
    parser.add_argument("--output_file", type=str, default="{{ output_file }}")
    parser.add_argument("--n_gpu_layers", type=int, default={{ n_gpu_layers | default(-1) }})
    parser.add_argument("--max_tokens", type=int, default={{ max_tokens | default(128) }})
    parser.add_argument("--n_ctx", type=int, default={{ n_ctx | default(2048) }})
    return parser.parse_args()


def main():
    args = parse_args()

    llm = Llama(
        model_path=args.model_path,
        n_gpu_layers=args.n_gpu_layers,
        n_ctx=args.n_ctx,
    )

    with open(args.input_file) as f:
        lines = [line.strip() for line in f if line.strip()]

    results = []
    for i, prompt in enumerate(lines):
        {% if special_handling %}
        {{ special_handling }}
        {% endif %}
        output = llm(prompt, max_tokens=args.max_tokens)
        generated = output["choices"][0]["text"]
        print(f"Sample {i}: input = {prompt}")
        print(f"  output = {generated[:200]}")
        results.append(f"[Sample {i}]\nInput: {prompt}\nOutput: {generated}\n")

    if args.output_file:
        with open(args.output_file, "w") as f:
            f.write("\n".join(results))
        print(f"\nResults saved to {args.output_file}")


if __name__ == "__main__":
    main()
