def parse_args():
    parser = argparse.ArgumentParser(description="Embedding model inference")
    parser.add_argument("--model_path", type=str, default="{{ model_path }}")
    parser.add_argument("--input_file", type=str, default="{{ input_file }}")
    parser.add_argument("--output_file", type=str, default="{{ output_file }}")
    parser.add_argument("--device", type=str, default="{{ device | default('cuda:0') }}")
    parser.add_argument("--max_length", type=int, default={{ max_length | default(512) }})
    parser.add_argument("--batch_size", type=int, default={{ batch_size | default(32) }})
    return parser.parse_args()


def main():
    args = parse_args()

    tokenizer = AutoTokenizer.from_pretrained(args.model_path, trust_remote_code=True)
    model = AutoModel.from_pretrained(
        args.model_path,
        trust_remote_code=True,
        device_map="auto",
        torch_dtype={{ torch_dtype | default('"auto"') }},
    )

    with open(args.input_file) as f:
        lines = [line.strip() for line in f if line.strip()]

    embeddings = []
    for i, text in enumerate(lines):
        {% if special_handling %}
        {{ special_handling }}
        {% endif %}
        inputs = tokenizer(
            text, return_tensors="pt", padding=True, truncation=True, max_length=args.max_length
        ).to(model.device)
        with torch.no_grad():
            output = model(**inputs, output_hidden_states=True)
        emb = output.last_hidden_state[:, 0, :].squeeze().cpu().numpy()
        embeddings.append(emb)
        print(f"Sample {i}: input = {text}")
        print(f"  shape = {emb.shape}, embedding[:5] = {emb[:5].tolist()}")

    if args.output_file:
        np.save(args.output_file, np.array(embeddings))
        print(f"\nEmbeddings saved to {args.output_file}")


if __name__ == "__main__":
    main()
